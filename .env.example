# Your deployed URL (update after first Vercel deploy)
NEXT_PUBLIC_APP_URL=https://asuka-ai-stylist.vercel.app

# Your Shopify store URL (for CORS)
SHOPIFY_STORE_URL=https://asukacouture.com

# Optional: Image generation (for Design Studio)
# REPLICATE_API_TOKEN=xxxxx
